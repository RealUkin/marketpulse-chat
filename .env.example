# Copy to .env.local and fill in. .env.local is gitignored — secrets never get committed.

# --- Core (optional; sensible defaults) ---
# WS_PORT=3001
# NEXT_PUBLIC_WS_URL=ws://localhost:3001

# --- Twitch sign-in (optional) ---
# Enables "Sign in with Twitch" so you can REPLY to your chat from the app.
# Reading chat needs no login. Register an app at https://dev.twitch.tv/console/apps
# with OAuth Redirect URL set to exactly http://localhost:3000, then paste the Client ID.
# There is no client secret — this is a public client (OAuth implicit grant).
# NEXT_PUBLIC_TWITCH_CLIENT_ID=

# --- Kick (optional) ---
# Hardcode a chatroom ID if Cloudflare blocks resolution on your network.
# KICK_CHATROOM_<SLUG>=

# --- X / Twitter (optional) ---
# Run the X capture browser headless.
# X_HEADLESS=1
